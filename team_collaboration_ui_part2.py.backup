    @app.route("/teams/<int:team_id>/templates")
    @team_required
    def team_templates(team_id):
        """Team bot templates"""
        conn = get_db_connection()

        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()

        # Get team templates
        templates = conn.execute("""
            SELECT tt.*, u.username as creator_name
            FROM team_templates tt
            JOIN users u ON tt.created_by = u.id
            WHERE tt.team_id = ?
            ORDER BY tt.updated_at DESC
        """, (team_id,)).fetchall()

        # Get template categories
        categories = conn.execute("""
            SELECT DISTINCT category
            FROM team_templates
            WHERE team_id = ? AND category IS NOT NULL
        """, (team_id,)).fetchall()

        conn.close()

        return render_template("team_templates.html",
                             team=team,
                             templates=templates,
                             categories=categories,
                             username=session.get("username"))

    @app.route("/teams/<int:team_id>/templates/create", methods=["GET", "POST"])
    @admin_required
    @team_required
    def create_team_template(team_id):
        """Create team template"""
        # Get team details
        conn = get_db_connection()
        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()
        conn.close()

        if request.method == "POST":
            name = request.form.get("name", "").strip()
            description = request.form.get("description", "").strip()
            config = request.form.get("config", "{}")
            category = request.form.get("category", "").strip()
            tags = request.form.get("tags", "").strip()

            if not name or not config:
                flash("Name and configuration are required.", "error")
                return render_template("team_template.html",
                                     team=team,
                                     username=session.get("username"))

            user_id = session["user_id"]

            # Validate JSON config
            try:
                config_obj = json.loads(config)
            except json.JSONDecodeError:
                flash("Invalid JSON configuration.", "error")
                return render_template("team_template.html",
                                     team=team,
                                     username=session.get("username"))

            conn = get_db_connection()

            try:
                # Create template
                conn.execute("""
                    INSERT INTO team_templates (team_id, name, description, config, category, created_by, tags)
                    VALUES (?, ?, ?, ?, ?, ?, ?)
                """, (team_id, name, description, config, category, user_id, tags))

                # Log activity
                log_team_activity(team_id, user_id, 'template_created', {
                    'template_name': name,
                    'category': category
                }, request)

                conn.commit()
                conn.close()

                flash(f"Template '{name}' created successfully!", "success")
                return redirect(url_for("team_templates", team_id=team_id))

            except Exception as e:
                conn.rollback()
                conn.close()
                flash(f"Error creating template: {str(e)}", "error")
                return render_template("team_template.html",
                                     team=team,
                                     username=session.get("username"))

        return render_template("team_template.html",
                             team=team,
                             username=session.get("username"))

    @app.route("/teams/<int:team_id>/settings", methods=["GET", "POST"])
    @team_admin_required
    def team_settings(team_id):
        """Team settings management"""
        if request.method == "POST":
            # Update team settings
            data = request.form

            conn = get_db_connection()

            try:
                # Get current settings
                team = conn.execute("SELECT settings FROM teams WHERE id = ?", (team_id,)).fetchone()
                current_settings = json.loads(team['settings']) if team['settings'] else {}

                # Update settings
                updated_settings = {
                    **current_settings,
                    'allow_public_invites': 'allow_public_invites' in data,
                    'default_role': data.get('default_role', 'member'),
                    'bot_sharing': 'bot_sharing' in data,
                    'message_history': int(data.get('message_history', 90))
                }

                # Update team
                conn.execute("""
                    UPDATE teams
                    SET settings = ?, updated_at = CURRENT_TIMESTAMP
                    WHERE id = ?
                """, (json.dumps(updated_settings), team_id))

                # Log activity
                log_team_activity(team_id, session["user_id"], 'settings_updated', {
                    'updated_fields': list(data.keys())
                }, request)

                conn.commit()
                conn.close()

                flash("Team settings updated successfully!", "success")

            except Exception as e:
                conn.rollback()
                conn.close()
                flash(f"Error updating settings: {str(e)}", "error")

            return redirect(url_for("team_settings", team_id=team_id))

        # GET request - show settings form
        conn = get_db_connection()
        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()

        # Parse settings
        settings = json.loads(team['settings']) if team['settings'] else {}

        conn.close()

        return render_template("team_settings.html",
                             team=team,
                             settings=settings,
                             username=session.get("username"))

    return app