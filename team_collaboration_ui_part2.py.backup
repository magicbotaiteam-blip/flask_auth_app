"""
Team Collaboration UI Part 2 - More routes and templates
"""

from flask import Flask, render_template, request, redirect, url_for, session, flash, jsonify
import sqlite3
from pathlib import Path
import json
from datetime import datetime, timedelta
import secrets
from functools import wraps

DB_FILENAME = Path(__file__).parent / "users.db"

def get_db_connection():
    """Get database connection with retry logic for locks"""
    import sqlite3
    import time

    max_retries = 5
    base_delay = 0.1  # seconds

    for attempt in range(max_retries):
        try:
            # Add timeout to handle database locks
            conn = sqlite3.connect('users.db', timeout=30)  # Increased timeout
            conn.row_factory = sqlite3.Row

            # Enable WAL mode for better concurrency
            conn.execute("PRAGMA journal_mode=WAL")

            # Set busy timeout (5 seconds)
            conn.execute("PRAGMA busy_timeout = 5000")

            # Set synchronous mode to NORMAL for better performance
            # (still safe with WAL mode)
            conn.execute("PRAGMA synchronous = NORMAL")

            # Enable foreign keys
            conn.execute("PRAGMA foreign_keys = ON")

            return conn

        except sqlite3.OperationalError as e:
            error_msg = str(e).lower()

            # Check for lock-related errors
            if any(lock_word in error_msg for lock_word in ['locked', 'busy', 'timeout']) \
               and attempt < max_retries - 1:

                # Exponential backoff with jitter
                delay = base_delay * (2 ** attempt) + (0.01 * attempt)
                time.sleep(delay)
                continue

            # Re-raise if not a lock error or out of retries
            raise

        except Exception as e:
            # Re-raise other exceptions
            raise
            raise
    # This should never be reached due to the raise above
    raise sqlite3.OperationalError("Failed to connect to database after retries")

def check_team_permission(user_id, team_id, required_role='member'):
    """Check if user has required permission in team"""
    conn = get_db_connection()
    member = conn.execute("""
        SELECT role FROM team_members
        WHERE user_id = ? AND team_id = ? AND status = 'active'
    """, (user_id, team_id)).fetchone()
    conn.close()

    if not member:
        return False

    # Role hierarchy: owner > admin > member > viewer
    role_hierarchy = {'owner': 4, 'admin': 3, 'member': 2, 'viewer': 1}
    user_role_level = role_hierarchy.get(member['role'], 0)
    required_role_level = role_hierarchy.get(required_role, 0)

    return user_role_level >= required_role_level

def log_team_activity(team_id, user_id, activity_type, activity_data=None, request=None):
    """Log team activity - SIMPLIFIED VERSION"""
    import sqlite3
    from pathlib import Path
    
    try:
        # Simple database connection
        db_path = Path(__file__).parent / 'users.db'
        conn = sqlite3.connect(str(db_path), timeout=5)
        conn.row_factory = sqlite3.Row
        
        ip_address = request.remote_addr if request else None
        user_agent = request.user_agent.string if request else None

        conn.execute("""
            INSERT INTO team_activity (team_id, user_id, activity_type, activity_data, ip_address, user_agent)
            VALUES (?, ?, ?, ?, ?, ?)
        """, (team_id, user_id, activity_type,
              json.dumps(activity_data) if activity_data else None,
              ip_address, user_agent))

        conn.commit()
        conn.close()
    except Exception as e:
        # Silently fail - activity logging is non-critical
        pass

def team_admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            return redirect(url_for("landing"))

        team_id = kwargs.get('team_id')
        if team_id and not check_team_permission(session["user_id"], team_id, 'admin'):
            flash("Admin permission required for this action.", "error")
            return redirect(url_for("team_dashboard", team_id=team_id))

        return f(*args, **kwargs)
    return decorated_function

def login_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            return redirect(url_for("landing"))
        return f(*args, **kwargs)
    return decorated_function

def team_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            return redirect(url_for("landing"))

        team_id = kwargs.get('team_id')
        if team_id and not check_team_permission(session["user_id"], team_id, 'viewer'):
            flash("You don't have access to this team.", "error")
            return redirect(url_for("teams"))

        return f(*args, **kwargs)
    return decorated_function

def admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if session.get('role', 'customer') != 'admin':
            flash("You do not have permission to access team features.", "error")
            return redirect(url_for("index"))
        return f(*args, **kwargs)
    return decorated_function

def create_team_collaboration_ui_part2(app):
    """
    More team collaboration UI routes
    """

    @app.route("/teams/<int:team_id>/invite", methods=["POST"])
    @team_admin_required
    def invite_to_team(team_id):
        """Invite someone to team - SIMPLIFIED VERSION TO AVOID DATABASE LOCKS"""
        import sqlite3
        from pathlib import Path
        print(f"DEBUG: invite_to_team called with team_id={team_id}")
        print(f"DEBUG: Form data: {dict(request.form)}")

        email = request.form.get("email", "").strip().lower()
        role = request.form.get("role", "member")

        if not email:
            flash("Email is required.", "error")
            return redirect(url_for("team_members", team_id=team_id))

        user_id = session["user_id"]

        # Validate role
        valid_roles = ['viewer', 'member', 'admin']
        if role not in valid_roles:
            role = 'member'

        # Simple approach - try once with minimal database operations
        conn = None
        try:
            print(f"DEBUG: Starting invite process for {email}")

            # Get connection with minimal configuration
            db_path = Path(__file__).parent / 'users.db'
            print(f"DEBUG: Connecting to database at: {db_path}")
            conn = sqlite3.connect(str(db_path), timeout=10)
            conn.row_factory = sqlite3.Row

            # Check if user already exists
            existing_user = conn.execute("SELECT * FROM users WHERE email = ?", (email,)).fetchone()

            if existing_user:
                # Check if already a member
                existing_member = conn.execute("""
                    SELECT * FROM team_members
                    WHERE team_id = ? AND user_id = ? AND status = 'active'
                """, (team_id, existing_user['id'])).fetchone()

                if existing_member:
                    conn.close()
                    flash(f"{email} is already a team member.", "warning")
                    return redirect(url_for("team_members", team_id=team_id))

            # Generate invitation token
            token = secrets.token_urlsafe(32)

            # Set expiration (7 days from now)
            expires_at = datetime.now() + timedelta(days=7)

            # Create invitation
            conn.execute("""
                INSERT INTO team_invitations (team_id, email, invited_by, token, role, expires_at)
                VALUES (?, ?, ?, ?, ?, ?)
            """, (team_id, email, user_id, token, role, expires_at))

            # Log activity (skip if it fails)
            try:
                log_team_activity(team_id, user_id, 'member_invited', {
                    'email': email,
                    'role': role,
                    'expires_at': expires_at.isoformat()
                }, request)
            except Exception as log_error:
                print(f"DEBUG: Failed to log activity (non-critical): {log_error}")

            conn.commit()
            conn.close()

            # Success
            flash(f"Invitation sent to {email}.", "success")
            print(f"DEBUG: Invitation sent successfully to {email}")

        except sqlite3.OperationalError as e:
            error_msg = str(e).lower()
            print(f"DEBUG: SQLite operational error: {e}")
            
            if conn:
                try:
                    conn.rollback()
                    conn.close()
                except:
                    pass
            
            if any(word in error_msg for word in ['locked', 'busy', 'timeout']):
                flash("Database is busy. Please try again in a moment.", "error")
            else:
                flash(f"Database error: {e}", "error")
                
        except Exception as e:
            print(f"DEBUG: General error: {e}")
            
            if conn:
                try:
                    conn.rollback()
                    conn.close()
                except:
                    pass
            
            flash(f"Error sending invitation: {e}", "error")
        
        print(f"DEBUG: Redirecting to team_members with team_id={team_id}")
        return redirect(url_for("team_members", team_id=team_id))

    @app.route("/teams/invite/accept/<token>")
    @login_required
    def accept_team_invitation(token):
        """Accept team invitation - SIMPLIFIED VERSION TO AVOID DATABASE LOCKS"""
        import sqlite3
        from pathlib import Path
        
        user_id = session["user_id"]
        print(f"DEBUG: accept_team_invitation called with token={token}, user_id={user_id}")
        
        conn = None
        try:
            # Simple database connection
            db_path = Path(__file__).parent / 'users.db'
            print(f"DEBUG: Connecting to database at: {db_path}")
            conn = sqlite3.connect(str(db_path), timeout=10)
            conn.row_factory = sqlite3.Row
            
            # Get invitation
            invitation = conn.execute("""
                SELECT ti.*, t.name as team_name
                FROM team_invitations ti
                JOIN teams t ON ti.team_id = t.id
                WHERE ti.token = ? AND ti.status = 'pending'
                AND ti.expires_at > CURRENT_TIMESTAMP
            """, (token,)).fetchone()

            if not invitation:
                conn.close()
                flash("Invalid or expired invitation.", "error")
                return redirect(url_for("teams"))

            # Get user email
            user = conn.execute("SELECT email FROM users WHERE id = ?", (user_id,)).fetchone()

            if not user or user['email'].lower() != invitation['email'].lower():
                conn.close()
                flash("This invitation is not for your account.", "error")
                return redirect(url_for("teams"))

            # Check if already a member
            existing_member = conn.execute("""
                SELECT * FROM team_members
                WHERE team_id = ? AND user_id = ? AND status = 'active'
            """, (invitation['team_id'], user_id)).fetchone()

            if existing_member:
                # Update invitation status
                conn.execute("""
                    UPDATE team_invitations
                    SET status = 'accepted'
                    WHERE id = ?
                """, (invitation['id'],))

                conn.commit()
                conn.close()
                flash(f"You are already a member of '{invitation['team_name']}'.", "info")
                return redirect(url_for("team_dashboard", team_id=invitation['team_id']))

            # Add user to team
            conn.execute("""
                INSERT INTO team_members (team_id, user_id, role, invited_by, status)
                VALUES (?, ?, ?, ?, 'active')
            """, (invitation['team_id'], user_id, invitation['role'], invitation['invited_by']))

            # Update invitation status
            conn.execute("""
                UPDATE team_invitations
                SET status = 'accepted'
                WHERE id = ?
            """, (invitation['id'],))

            # Log activity (skip if it fails)
            try:
                log_team_activity(invitation['team_id'], user_id, 'member_joined', {
                    'invitation_id': invitation['id'],
                    'role': invitation['role']
                }, request)
            except Exception as log_error:
                print(f"DEBUG: Failed to log activity (non-critical): {log_error}")

            conn.commit()
            conn.close()

            flash(f"You have joined '{invitation['team_name']}'!", "success")
            print(f"DEBUG: Successfully joined team {invitation['team_id']}")
            return redirect(url_for("team_dashboard", team_id=invitation['team_id']))

        except sqlite3.OperationalError as e:
            error_msg = str(e).lower()
            print(f"DEBUG: SQLite operational error: {e}")
            
            if conn:
                try:
                    conn.rollback()
                    conn.close()
                except:
                    pass
            
            if any(word in error_msg for word in ['locked', 'busy', 'timeout']):
                flash("Database is busy. Please try again in a moment.", "error")
            else:
                flash(f"Database error: {e}", "error")
            return redirect(url_for("teams"))
                
        except Exception as e:
            print(f"DEBUG: General error: {e}")
            
            if conn:
                try:
                    conn.rollback()
                    conn.close()
                except:
                    pass
            
            flash(f"Error accepting invitation: {e}", "error")
            return redirect(url_for("teams"))

    @app.route("/teams/<int:team_id>/members")
    @team_required
    def team_members(team_id):
        """Team members management"""
        conn = get_db_connection()

        # Get team details
        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()

        # Get team members with user details
        members = conn.execute("""
            SELECT
                tm.*,
                u.username,
                u.email,
                u.provider
            FROM team_members tm
            JOIN users u ON tm.user_id = u.id
            WHERE tm.team_id = ?
            ORDER BY
                CASE tm.role
                    WHEN 'owner' THEN 1
                    WHEN 'admin' THEN 2
                    WHEN 'member' THEN 3
                    WHEN 'viewer' THEN 4
                    ELSE 5
                END,
                tm.joined_at
        """, (team_id,)).fetchall()

        # Get pending invitations
        invitations = conn.execute("""
            SELECT ti.*, u.username as invited_by_name
            FROM team_invitations ti
            LEFT JOIN users u ON ti.invited_by = u.id
            WHERE ti.team_id = ? AND ti.status = 'pending'
            ORDER BY ti.created_at DESC
        """, (team_id,)).fetchall()

        # Get user's role in this team
        user_role = conn.execute("""
            SELECT role FROM team_members
            WHERE team_id = ? AND user_id = ?
        """, (team_id, session["user_id"])).fetchone()

        conn.close()

        return render_template("team_members.html",
                             team=team,
                             members=members,
                             invitations=invitations,
                             user_role=user_role["role"] if user_role else None,
                             username=session.get("username"))

    @app.route("/teams/<int:team_id>/bots")
    @team_required
    def team_bots(team_id):
        """Team shared bots"""
        conn = get_db_connection()

        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()

        # Get shared bots with details
        shared_bots_raw = conn.execute("""
            SELECT
                b.*,
                sb.id as share_id,
                sb.permissions,
                sb.shared_at,
                sb.shared_by,
                u.username as shared_by_name,
                tm.role as user_role
            FROM shared_bots sb
            JOIN bots b ON sb.bot_id = b.id
            JOIN users u ON sb.shared_by = u.id
            JOIN team_members tm ON tm.team_id = sb.team_id AND tm.user_id = ?
            WHERE sb.team_id = ? AND b.is_active = TRUE
            ORDER BY sb.shared_at DESC
        """, (session["user_id"], team_id)).fetchall()

        # Parse permissions JSON for shared bots
        shared_bots = []
        for bot in shared_bots_raw:
            bot_dict = dict(bot)
            # Parse permissions if it exists
            if bot_dict.get('permissions'):
                try:
                    bot_dict['permissions_parsed'] = json.loads(bot_dict['permissions'])
                except:
                    bot_dict['permissions_parsed'] = {}
            else:
                bot_dict['permissions_parsed'] = {}
            shared_bots.append(bot_dict)

        # Get user's personal bots that aren't shared yet
        user_bots = conn.execute("""
            SELECT b.* FROM bots b
            WHERE b.user_id = ?
            AND b.id NOT IN (
                SELECT bot_id FROM shared_bots
                WHERE team_id = ? AND is_active = TRUE
            )
            ORDER BY b.created_at DESC
        """, (session["user_id"], team_id)).fetchall()

        conn.close()

        return render_template("team_bots.html",
                             team=team,
                             shared_bots=shared_bots,
                             user_bots=user_bots,
                             username=session.get("username"))

    @app.route("/teams/<int:team_id>/bots/<int:bot_id>") 
    @team_required
    def team_bot_detail(team_id, bot_id):
        """View bot details within team context"""
        conn = get_db_connection()
        
        # Get team
        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()
        
        # Check if bot is shared with this team
        shared_bot = conn.execute("""
            SELECT b.*, sb.permissions, sb.shared_at, sb.shared_by,
                   u.username as shared_by_name
            FROM shared_bots sb
            JOIN bots b ON sb.bot_id = b.id
            JOIN users u ON sb.shared_by = u.id
            WHERE sb.team_id = ? AND sb.bot_id = ? AND sb.is_active = TRUE
        """, (team_id, bot_id)).fetchone()
        
        if not shared_bot:
            conn.close()
            flash("Bot not found in this team or access denied.", "error")
            return redirect(url_for("team_bots", team_id=team_id))
        
        # Parse permissions
        import json
        bot_dict = dict(shared_bot)
        if bot_dict.get('permissions'):
            try:
                bot_dict['permissions_parsed'] = json.loads(bot_dict['permissions'])
            except:
                bot_dict['permissions_parsed'] = {}
        else:
            bot_dict['permissions_parsed'] = {}
        
        conn.close()
        
        return render_template("bot_detail.html",
                             bot=bot_dict,
                             team=team,
                             session_username=session.get("username"),
                             role=session.get("role", "customer"))

    @app.route("/teams/<int:team_id>/bots/share", methods=["POST"])
    @team_required
    def share_bot_with_team(team_id):
        """Share a bot with team"""
        bot_id = request.form.get("bot_id")
        permissions = request.form.get("permissions", "{}")

        if not bot_id:
            flash("Bot ID is required.", "error")
            return redirect(url_for("team_bots", team_id=team_id))

        user_id = session["user_id"]

        # Verify bot ownership
        conn = get_db_connection()
        bot = conn.execute("SELECT * FROM bots WHERE id = ? AND user_id = ?", (bot_id, user_id)).fetchone()

        if not bot:
            conn.close()
            flash("Bot not found or you don't own it.", "error")
            return redirect(url_for("team_bots", team_id=team_id))

        # Check if already shared
        existing_share = conn.execute("""
            SELECT * FROM shared_bots
            WHERE bot_id = ? AND team_id = ? AND is_active = TRUE
        """, (bot_id, team_id)).fetchone()

        if existing_share:
            conn.close()
            flash("This bot is already shared with the team.", "warning")
            return redirect(url_for("team_bots", team_id=team_id))

        try:
            # Share bot
            conn.execute("""
                INSERT INTO shared_bots (bot_id, team_id, shared_by, permissions)
                VALUES (?, ?, ?, ?)
            """, (bot_id, team_id, user_id, permissions))

            # Log activity
            log_team_activity(team_id, user_id, 'bot_shared', {
                'bot_id': bot_id,
                'bot_name': bot['name'],
                'permissions': permissions
            }, request)

            conn.commit()
            conn.close()

            flash(f"Bot '{bot['name']}' shared with team successfully!", "success")

        except Exception as e:
            conn.rollback()
            conn.close()
            flash(f"Error sharing bot: {str(e)}", "error")

        return redirect(url_for("team_bots", team_id=team_id))

    @app.route("/teams/<int:team_id>/bots/<int:share_id>/unshare", methods=["POST"])
    @team_required
    def unshare_bot(team_id, share_id):
        """Unshare a bot from team"""
        user_id = session["user_id"]

        conn = get_db_connection()

        # Get share info
        share = conn.execute("""
            SELECT sb.*, b.name as bot_name
            FROM shared_bots sb
            JOIN bots b ON sb.bot_id = b.id
            WHERE sb.id = ? AND sb.team_id = ?
        """, (share_id, team_id)).fetchone()

        if not share:
            conn.close()
            flash("Share not found.", "error")
            return redirect(url_for("team_bots", team_id=team_id))

        # Check permission (only owner or bot owner can unshare)
        user_role = conn.execute("""
            SELECT role FROM team_members
            WHERE team_id = ? AND user_id = ? AND status = 'active'
        """, (team_id, user_id)).fetchone()

        is_bot_owner = share['shared_by'] == user_id
        is_team_owner = user_role and user_role['role'] == 'owner'

        if not (is_bot_owner or is_team_owner):
            conn.close()
            flash("You don't have permission to unshare this bot.", "error")
            return redirect(url_for("team_bots", team_id=team_id))

        try:
            # Soft delete (set inactive)
            conn.execute("""
                UPDATE shared_bots
                SET is_active = FALSE
                WHERE id = ?
            """, (share_id,))

            # Log activity
            log_team_activity(team_id, user_id, 'bot_unshared', {
                'bot_id': share['bot_id'],
                'bot_name': share['bot_name'],
                'share_id': share_id
            }, request)

            conn.commit()
            conn.close()

            flash(f"Bot '{share['bot_name']}' unshared from team.", "success")

        except Exception as e:
            conn.rollback()
            conn.close()
            flash(f"Error unsharing bot: {str(e)}", "error")

        return redirect(url_for("team_bots", team_id=team_id))

