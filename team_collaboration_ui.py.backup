"""
Team Collaboration UI Implementation
For Magic Bot AI Flask Application
"""

from flask import Flask, render_template, request, redirect, url_for, session, flash, jsonify
import sqlite3
from pathlib import Path
import json
from datetime import datetime
from functools import wraps

DB_FILENAME = Path(__file__).parent / "users.db"

# ==================== Database Functions ====================

def get_db_connection():
    """Get database connection with retry logic for locks"""
    max_retries = 3
    retry_delay = 0.1  # seconds
    
    for attempt in range(max_retries):
        try:
            # Add timeout to handle database locks
            conn = sqlite3.connect(DB_FILENAME, timeout=10)
            conn.row_factory = sqlite3.Row
            # Enable WAL mode for better concurrency
            conn.execute("PRAGMA journal_mode=WAL")
            # Set busy timeout
            conn.execute("PRAGMA busy_timeout = 5000")
            return conn
        except sqlite3.OperationalError as e:
            if "locked" in str(e).lower() and attempt < max_retries - 1:
                import time
                time.sleep(retry_delay * (attempt + 1))  # Exponential backoff
                continue
            raise
    # This should never be reached due to the raise above
    raise sqlite3.OperationalError("Failed to connect to database after retries")

def init_team_db():
    """Initialize database tables for team collaboration"""
    conn = get_db_connection()
    
    # Teams table
    conn.execute("""
        CREATE TABLE IF NOT EXISTS teams (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            description TEXT,
            created_by INTEGER NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            is_active BOOLEAN DEFAULT TRUE,
            settings TEXT DEFAULT '{}',
            FOREIGN KEY (created_by) REFERENCES users (id) ON DELETE CASCADE
        )
    """)
    
    # Team members table with roles
    conn.execute("""
        CREATE TABLE IF NOT EXISTS team_members (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            team_id INTEGER NOT NULL,
            user_id INTEGER NOT NULL,
            role TEXT NOT NULL DEFAULT 'member',  -- owner, admin, member, viewer
            joined_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            invited_by INTEGER,
            status TEXT DEFAULT 'active',  -- active, pending, suspended
            permissions TEXT DEFAULT '{}',
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE,
            FOREIGN KEY (invited_by) REFERENCES users (id) ON DELETE SET NULL,
            UNIQUE(team_id, user_id)
        )
    """)
    
    # Team invitations table
    conn.execute("""
        CREATE TABLE IF NOT EXISTS team_invitations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            team_id INTEGER NOT NULL,
            email TEXT NOT NULL,
            invited_by INTEGER NOT NULL,
            token TEXT NOT NULL UNIQUE,
            role TEXT DEFAULT 'member',
            status TEXT DEFAULT 'pending',  -- pending, accepted, expired, revoked
            expires_at TIMESTAMP,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (invited_by) REFERENCES users (id) ON DELETE CASCADE
        )
    """)
    
    # Shared bots table
    conn.execute("""
        CREATE TABLE IF NOT EXISTS shared_bots (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            bot_id INTEGER NOT NULL,
            team_id INTEGER NOT NULL,
            shared_by INTEGER NOT NULL,
            shared_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            permissions TEXT DEFAULT '{}',
            is_active BOOLEAN DEFAULT TRUE,
            FOREIGN KEY (bot_id) REFERENCES bots (id) ON DELETE CASCADE,
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (shared_by) REFERENCES users (id) ON DELETE CASCADE,
            UNIQUE(bot_id, team_id)
        )
    """)
    
    # Team activity log
    conn.execute("""
        CREATE TABLE IF NOT EXISTS team_activity (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            team_id INTEGER NOT NULL,
            user_id INTEGER NOT NULL,
            activity_type TEXT NOT NULL,
            activity_data TEXT,
            ip_address TEXT,
            user_agent TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE
        )
    """)
    
    # Team messages/chat
    conn.execute("""
        CREATE TABLE IF NOT EXISTS team_messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            team_id INTEGER NOT NULL,
            user_id INTEGER NOT NULL,
            message TEXT NOT NULL,
            message_type TEXT DEFAULT 'text',  -- text, file, bot_update, system
            file_url TEXT,
            file_name TEXT,
            file_size INTEGER,
            parent_id INTEGER,
            is_pinned BOOLEAN DEFAULT FALSE,
            is_edited BOOLEAN DEFAULT FALSE,
            edited_at TIMESTAMP,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (user_id) REFERENCES users (id) ON DELETE CASCADE,
            FOREIGN KEY (parent_id) REFERENCES team_messages (id) ON DELETE SET NULL
        )
    """)
    
    # Team templates
    conn.execute("""
        CREATE TABLE IF NOT EXISTS team_templates (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            team_id INTEGER NOT NULL,
            name TEXT NOT NULL,
            description TEXT,
            config TEXT NOT NULL,
            category TEXT,
            created_by INTEGER NOT NULL,
            is_public BOOLEAN DEFAULT FALSE,
            usage_count INTEGER DEFAULT 0,
            tags TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (team_id) REFERENCES teams (id) ON DELETE CASCADE,
            FOREIGN KEY (created_by) REFERENCES users (id) ON DELETE CASCADE
        )
    """)
    
    conn.commit()
    conn.close()

init_team_db()

# ==================== Helper Functions ====================

def get_user_teams(user_id):
    """Get all teams a user belongs to"""
    conn = get_db_connection()
    teams = conn.execute("""
        SELECT t.*, tm.role, tm.joined_at
        FROM teams t
        JOIN team_members tm ON t.id = tm.team_id
        WHERE tm.user_id = ? AND tm.status = 'active' AND t.is_active = TRUE
        ORDER BY t.created_at DESC
    """, (user_id,)).fetchall()
    conn.close()
    return teams

def get_team_members(team_id):
    """Get all members of a team"""
    conn = get_db_connection()
    members = conn.execute("""
        SELECT u.id, u.username, u.email, tm.role, tm.joined_at, tm.status
        FROM team_members tm
        JOIN users u ON tm.user_id = u.id
        WHERE tm.team_id = ? AND tm.status = 'active'
        ORDER BY 
            CASE tm.role 
                WHEN 'owner' THEN 1
                WHEN 'admin' THEN 2
                WHEN 'member' THEN 3
                ELSE 4
            END,
            tm.joined_at
    """, (team_id,)).fetchall()
    conn.close()
    return members

def check_team_permission(team_id, user_id, required_role='member'):
    """Check if user has required permission for a team"""
    conn = get_db_connection()
    member = conn.execute("""
        SELECT role FROM team_members 
        WHERE team_id = ? AND user_id = ? AND status = 'active'
    """, (team_id, user_id)).fetchone()
    conn.close()
    
    if not member:
        return False
    
    role_hierarchy = {'owner': 3, 'admin': 2, 'member': 1, 'viewer': 0}
    user_role_level = role_hierarchy.get(member['role'], 0)
    required_role_level = role_hierarchy.get(required_role, 0)
    
    return user_role_level >= required_role_level

def log_team_activity(team_id, user_id, activity_type, activity_data=None, request=None):
    """Log team activity"""
    conn = get_db_connection()
    conn.execute("""
        INSERT INTO team_activity (team_id, user_id, activity_type, activity_data, ip_address, user_agent)
        VALUES (?, ?, ?, ?, ?, ?)
    """, (
        team_id,
        user_id,
        activity_type,
        json.dumps(activity_data) if activity_data else None,
        request.remote_addr if request else None,
        request.user_agent.string if request and request.user_agent else None
    ))
    conn.commit()
    conn.close()

# ==================== Decorators ====================

def login_required(f):
    """Decorator to require login"""
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            flash("Please log in to access this page.", "error")
            return redirect(url_for("signin_local"))
        return f(*args, **kwargs)
    return decorated_function

def team_required(f):
    """Decorator to require team membership"""
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            flash("Please log in to access this page.", "error")
            return redirect(url_for("signin_local"))
        
        team_id = kwargs.get('team_id')
        if not team_id:
            flash("Team not specified.", "error")
            return redirect(url_for("teams"))
        
        if not check_team_permission(team_id, session["user_id"], 'viewer'):
            flash("You don't have permission to access this team.", "error")
            return redirect(url_for("teams"))
        
        return f(*args, **kwargs)
    return decorated_function

def team_admin_required(f):
    """Decorator to require team admin permissions"""
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if "user_id" not in session:
            flash("Please log in to access this page.", "error")
            return redirect(url_for("signin_local"))
        
        team_id = kwargs.get('team_id')
        if not team_id:
            flash("Team not specified.", "error")
            return redirect(url_for("teams"))
        
        if not check_team_permission(team_id, session["user_id"], 'admin'):
            flash("You need admin permissions for this action.", "error")
            return redirect(url_for("team_dashboard", team_id=team_id))
        
        return f(*args, **kwargs)
    return decorated_function

# ==================== Team Collaboration UI Routes ====================

def admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        return f(*args, **kwargs)
    return decorated_function

def create_team_collaboration_ui(app):
    """
    Add team collaboration UI routes to Flask app
    """
    
    @app.route("/teams")
    @login_required
    def teams():
        """List user's teams and invitations"""
        user_id = session["user_id"]
        
        # Get user's teams (teams they belong to)
        user_teams = get_user_teams(user_id)
        
        # Get teams created by the user
        conn = get_db_connection()
        created_teams = conn.execute("""
            SELECT t.*, 'owner' as role, t.created_at as joined_at
            FROM teams t
            WHERE t.created_by = ? AND t.is_active = TRUE
            ORDER BY t.created_at DESC
        """, (user_id,)).fetchall()
        
        # Get pending invitations
        invitations = conn.execute("""
            SELECT ti.*, t.name as team_name, u.username as inviter_name
            FROM team_invitations ti
            JOIN teams t ON ti.team_id = t.id
            JOIN users u ON ti.invited_by = u.id
            WHERE ti.email = (
                SELECT email FROM users WHERE id = ?
            ) AND ti.status = 'pending' AND ti.expires_at > CURRENT_TIMESTAMP
        """, (user_id,)).fetchall()
        conn.close()
        
        return render_template("teams.html", 
                             teams=user_teams, 
                             created_teams=created_teams,
                             invitations=invitations,
                             username=session.get("username"))
    
    @app.route("/teams/create", methods=["GET", "POST"])
    @login_required
    def create_team():
        """Create a new team - FIXED VERSION WITH PROPER TRANSACTION HANDLING"""
        if request.method == "POST":
            name = request.form.get("name", "").strip()
            description = request.form.get("description", "").strip()
            
            if not name:
                flash("Team name is required.", "error")
                return render_template("create_team.html", username=session.get("username"))
            
            user_id = session["user_id"]
            
            # Check if team name already exists for this user
            conn = get_db_connection()
            existing = conn.execute("""
                SELECT * FROM teams WHERE name = ? AND created_by = ?
            """, (name, user_id)).fetchone()
            conn.close()
            
            if existing:
                flash("You already have a team with this name.", "error")
                return render_template("create_team.html", username=session.get("username"))
            
            # Create team with transaction
            conn = None
            try:
                conn = get_db_connection()
                
                # Start explicit transaction with immediate lock
                conn.execute("BEGIN IMMEDIATE")
                
                # Execute INSERT and capture the cursor
                cursor = conn.execute("""
                    INSERT INTO teams (name, description, created_by, settings)
                    VALUES (?, ?, ?, ?)
                """, (name, description, user_id, json.dumps({
                    "allow_public_invites": False,
                    "default_role": "member",
                    "bot_sharing": True,
                    "message_history": 90  # days
                })))
                
                # Get the last insert ID from the cursor
                team_id = cursor.lastrowid
                
                # Add creator as owner
                conn.execute("""
                    INSERT INTO team_members (team_id, user_id, role, invited_by)
                    VALUES (?, ?, ?, ?)
                """, (team_id, user_id, 'owner', user_id))
                
                # Commit transaction
                conn.commit()
                conn.close()
                conn = None
                
                # Log activity (with a new connection to avoid locks)
                try:
                    log_team_activity(team_id, user_id, 'team_created', {
                        'team_name': name,
                        'description': description
                    }, request)
                except Exception as log_error:
                    print(f"Warning: Failed to log activity: {log_error}")
                    # Don't fail team creation if logging fails
                
                flash(f"Team '{name}' created successfully!", "success")
                return redirect(url_for("team_dashboard", team_id=team_id))
                
            except Exception as e:
                # Clean up connection
                if conn:
                    try:
                        conn.rollback()
                        conn.close()
                    except:
                        pass
                
                flash(f"Error creating team: {e}", "error")
                return render_template("create_team.html", username=session.get("username"))
        
        # GET request - show form
        return render_template("create_team.html", username=session.get("username"))
    
    @app.route("/teams/<int:team_id>")
    @team_required
    def team_dashboard(team_id):
        """Team dashboard"""
        conn = get_db_connection()
        
        # Get team info
        team = conn.execute("SELECT * FROM teams WHERE id = ?", (team_id,)).fetchone()
        
        # Get team members
        members = get_team_members(team_id)
        
        # Get team bots
        bots = conn.execute("""
            SELECT b.*, sb.shared_at, sb.permissions as share_permissions,
                   u.username as shared_by_name
            FROM shared_bots sb
            JOIN bots b ON sb.bot_id = b.id
            JOIN users u ON sb.shared_by = u.id
            WHERE sb.team_id = ?
            ORDER BY sb.shared_at DESC
        """, (team_id,)).fetchall()
        
        # Get recent activity
        activity = conn.execute("""
            SELECT ta.*, u.username
            FROM team_activity ta
            JOIN users u ON ta.user_id = u.id
            WHERE ta.team_id = ?
            ORDER BY ta.created_at DESC
            LIMIT 20
        """, (team_id,)).fetchall()
        
        # Get recent messages
        recent_messages = conn.execute("""
            SELECT tm.*, u.username
            FROM team_messages tm
            JOIN users u ON tm.user_id = u.id
            WHERE tm.team_id = ? AND tm.message_type = 'text'
            ORDER BY tm.created_at DESC
            LIMIT 10
        """, (team_id,)).fetchall()
        
        conn.close()
        
        return render_template("team_dashboard.html",
                             team=team,
                             members=members,
                             bots=bots,
                             activity=activity,
                             messages=recent_messages,
                             username=session.get("username"))
    
    # Note: The rest of the functions are in team_collaboration_ui_part2.py