{
  "family": "flask-auth-app-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::404006608636:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "flask-auth-app",
      "image": "404006608636.dkr.ecr.us-east-1.amazonaws.com/flask-auth-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "OAUTHLIB_INSECURE_TRANSPORT",
          "value": "true"
        }
      ],
      "secrets": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/flask-auth-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
