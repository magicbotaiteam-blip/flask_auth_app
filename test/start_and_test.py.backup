#!/usr/bin/env python3
"""
Start the app and test if it works
"""

import subprocess
import time
import os
import sys

print("Starting Magic Bot AI on port 5000...")
print("=" * 60)

# Start the app
proc = subprocess.Popen(
    [sys.executable, "app_complete_with_teams.py"],
    stdout=subprocess.PIPE,
    stderr=subprocess.PIPE,
    text=True
)

# Wait for startup
print("Waiting for app to start...")
time.sleep(3)

# Check if it's running
if proc.poll() is None:
    print("✅ App is running!")
    
    # Try to access it
    import requests
    try:
        response = requests.get('http://localhost:5000/landing', timeout=5)
        if response.status_code == 200:
            print("✅ Landing page loaded successfully")
            print(f"✅ Response size: {len(response.text)} bytes")
            
            # Check for expected content
            if 'Magic Bot AI' in response.text:
                print("✅ 'Magic Bot AI' found in page")
            else:
                print("⚠️  'Magic Bot AI' not found in page")
                
            if 'Team Collaboration' in response.text:
                print("✅ Team Collaboration features mentioned")
            else:
                print("⚠️  Team Collaboration not mentioned")
        else:
            print(f"❌ HTTP Status: {response.status_code}")
    except Exception as e:
        print(f"❌ Could not connect: {e}")
    
    # Kill the app
    print("\nStopping app...")
    proc.terminate()
    proc.wait()
    print("✅ App stopped")
    
else:
    # App exited, show error
    stdout, stderr = proc.communicate()
    print("❌ App failed to start")
    print("\nError output:")
    print("-" * 40)
    print(stderr)
    
    print("\nStandard output:")
    print("-" * 40)
    print(stdout)

print("\n" + "=" * 60)
print("Test complete!")