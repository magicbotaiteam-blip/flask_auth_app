#!/usr/bin/env python3
"""
Test the template fix
"""

import os

# Remove old database
if os.path.exists('users.db'):
    os.remove('users.db')

print("Testing template fix...")
print("=" * 60)

from app_complete_with_teams import app, init_db_complete
init_db_complete()
print("✅ Database initialized")

# Create test data
from team_collaboration_ui import get_db_connection
conn = get_db_connection()

# Create user
conn.execute("""
    INSERT INTO users (provider, username, email, password_hash) 
    VALUES (?, ?, ?, ?)
""", ('test', 'template_test', 'test@test.com', 'hash'))

cursor = conn.execute("SELECT last_insert_rowid()")
user_id = cursor.fetchone()[0]

# Create team
conn.execute("""
    INSERT INTO teams (name, description, created_by, settings)
    VALUES (?, ?, ?, ?)
""", ('Test Team', 'Test team for templates', user_id, '{}'))

cursor = conn.execute("SELECT last_insert_rowid()")
team_id = cursor.fetchone()[0]

# Add user to team as owner
conn.execute("""
    INSERT INTO team_members (team_id, user_id, role, invited_by, status)
    VALUES (?, ?, ?, ?, ?)
""", (team_id, user_id, 'owner', user_id, 'active'))

conn.commit()
conn.close()

print(f"✅ Created test user (ID: {user_id}) and team (ID: {team_id})")

# Test the create_team_template function
from flask import Flask, session
test_app = Flask(__name__)
test_app.secret_key = 'test'

# Register all routes
from telegram_bot_api import create_telegram_bot_api
from telegram_bot_api_part2 import create_telegram_bot_api_part2
from team_collaboration_ui import create_team_collaboration_ui
from team_collaboration_ui_part2 import create_team_collaboration_ui_part2

create_telegram_bot_api(test_app)
create_telegram_bot_api_part2(test_app)
create_team_collaboration_ui(test_app)
create_team_collaboration_ui_part2(test_app)

print("✅ All routes registered")

# Test with request context
with test_app.test_request_context(f'/teams/{team_id}/templates/create'):
    session['user_id'] = user_id
    session['username'] = 'template_test'
    
    try:
        # Get the function
        create_template_func = test_app.view_functions['create_team_template']
        
        # Call it (GET request)
        response = create_template_func(team_id)
        
        print("✅ create_team_template function executes successfully!")
        print("✅ No TemplateNotFound error!")
        print("✅ Using correct template: team_template.html")
        
    except Exception as e:
        print(f"❌ Error: {e}")
        import traceback
        traceback.print_exc()

print("\n" + "=" * 60)
print("✅ TEMPLATE FIX TESTED!")
print(f"The /teams/{team_id}/templates/create page should now work.")
print("No more 'TemplateNotFound: create_team_template.html' error.")
print("=" * 60)